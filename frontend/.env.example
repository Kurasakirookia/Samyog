# ============ FRONTEND ENVIRONMENT VARIABLES ============
# Copy this file to .env.local and update with your actual values

# ============ API CONFIGURATION ============
# Backend API URL - Update with your deployed backend URL
REACT_APP_API_URL=http://localhost:5001/api

# ============ APPLICATION SETTINGS ============
# Application name and branding
REACT_APP_APP_NAME=EduManage
REACT_APP_COLLEGE_NAME="EduManage College"

# ============ ENVIRONMENT ============
# Current environment (development, staging, production)
REACT_APP_ENV=development

# ============ ANALYTICS (Optional) ============
# Google Analytics tracking ID
# REACT_APP_GA_TRACKING_ID=GA_MEASUREMENT_ID

# ============ SOCIAL MEDIA (Optional) ============
# Social media handles for footer links
REACT_APP_FACEBOOK_URL=https://facebook.com/edumanage
REACT_APP_TWITTER_URL=https://twitter.com/edumanage
REACT_APP_LINKEDIN_URL=https://linkedin.com/company/edumanage
REACT_APP_INSTAGRAM_URL=https://instagram.com/edumanage

# ============ CONTACT INFORMATION ============
# College contact details
REACT_APP_CONTACT_EMAIL=info@edumanage.edu
REACT_APP_CONTACT_PHONE=+1 (555) 123-4567
REACT_APP_CONTACT_ADDRESS="123 Education Street, Knowledge City, KC 12345"

# ============ FEATURES FLAGS (Optional) ============
# Enable/disable features
REACT_APP_ENABLE_DARK_MODE=false
REACT_APP_ENABLE_NOTIFICATIONS=true
REACT_APP_ENABLE_PWA=true

# ============ EXTERNAL SERVICES (Optional) ============
# Image hosting service (Cloudinary, AWS S3, etc.)
# REACT_APP_CLOUDINARY_CLOUD_NAME=your-cloud-name
# REACT_APP_AWS_S3_BUCKET=your-bucket-name

# ============ SECURITY ============
# CORS allowed origins (for production)
# REACT_APP_CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ============ DEPLOYMENT SETTINGS ============
# Build settings for different environments
GENERATE_SOURCEMAP=true
SKIP_PREFLIGHT_CHECK=true