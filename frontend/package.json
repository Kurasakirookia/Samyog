{
  "name": "edumanage-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "Frontend for EduManage - College Management System",
  "homepage": "https://yourusername.github.io/edumanage",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/edumanage.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/edumanage/issues"
  },
  "keywords": [
    "react",
    "college-management",
    "education",
    "frontend",
    "tailwindcss"
  ],
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.8.0",
    "react-scripts": "5.0.1",
    "axios": "^1.3.0",
    "react-toastify": "^9.1.0",
    "tailwindcss": "^3.2.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^14.4.3",
    "web-vitals": "^3.1.0",
    "gh-pages": "^6.1.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "test:coverage": "react-scripts test --coverage --watchAll=false",
    "eject": "react-scripts eject",
    "analyze": "npm run build && npx serve -s build",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d build",
    "deploy:netlify": "npm run build && netlify deploy --prod --dir=build",
    "preview:netlify": "npm run build && netlify deploy --dir=build"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "jest": {
    "collectCoverageFrom": [
      "src/**/*.{js,jsx}",
      "!src/index.js",
      "!src/reportWebVitals.js"
    ]
  }
}